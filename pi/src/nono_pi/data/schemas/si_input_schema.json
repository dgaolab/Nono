{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nono-pi Significance & Innovation input",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "significance": {"type": "array", "items": {"type": "string"}},
    "innovation": {"type": "array", "items": {"type": "string"}},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim"],
        "properties": {
          "claim": {"type": "string"},
          "pmids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "caveats": {"type": "array", "items": {"type": "string"}}
  }
}
