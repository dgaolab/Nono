{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nono-pi further-analysis plan input",
  "type": "object",
  "required": ["goal", "analyses"],
  "properties": {
    "goal": {"type": "string", "minLength": 1},
    "analyses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "gap", "rationale", "method", "expected_output"],
        "properties": {
          "name": {"type": "string"},
          "gap": {"type": "string"},
          "rationale": {"type": "string"},
          "method": {"type": "string"},
          "expected_output": {"type": "string"},
          "inputs": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
