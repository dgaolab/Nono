{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nono-pi subtopics decomposition",
  "type": "object",
  "required": ["topic", "subtopics"],
  "properties": {
    "topic": {"type": "string", "minLength": 1},
    "subtopics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "slug": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    }
  }
}
