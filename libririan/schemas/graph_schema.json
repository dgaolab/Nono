{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge Graph Manifest",
  "description": "Schema for KG manifest.json — the Tier 1 compact index of a knowledge graph",
  "type": "object",
  "required": ["kg_name", "topic", "created", "updated", "version", "nodes", "edges", "statistics"],
  "properties": {
    "kg_name": {
      "type": "string",
      "pattern": "^KG_",
      "description": "Folder name of the knowledge graph, prefixed with KG_"
    },
    "topic": {
      "type": "string",
      "description": "Full topic description as provided by the user"
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "ISO date when the KG was first created"
    },
    "updated": {
      "type": "string",
      "format": "date",
      "description": "ISO date of the most recent update"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Incremented on each update"
    },
    "data_sources": {
      "type": "array",
      "items": { "type": "string", "enum": ["pubmed", "clinicaltrials", "chembl", "user_provided"] },
      "description": "Data sources used in building this KG"
    },
    "schedule": {
      "type": "object",
      "description": "Optional: present when a cron job is active for this KG",
      "properties": {
        "cron": {
          "type": "string",
          "description": "Cron expression for the schedule"
        },
        "last_run": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO timestamp of the last scheduled run (null before first run)"
        },
        "trigger_name": {
          "type": "string",
          "description": "Name of the Claude Code remote trigger"
        }
      },
      "required": ["cron", "trigger_name"]
    },
    "nodes": {
      "type": "array",
      "description": "Compact index of all knowledge nodes — summaries and keywords enable RAG subsetting without reading full node files",
      "items": {
        "type": "object",
        "required": ["id", "title", "file", "tags", "summary", "keywords", "pubmed_ids", "evaluation_status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^node_\\d+$",
            "description": "Unique node identifier"
          },
          "title": {
            "type": "string",
            "description": "Short descriptive title"
          },
          "file": {
            "type": "string",
            "description": "Relative path to the node markdown file"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Category and topic tags for filtering"
          },
          "summary": {
            "type": "string",
            "description": "One-sentence distillation of the knowledge unit"
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Search terms for RAG relevance matching"
          },
          "pubmed_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of PubMed IDs supporting this node"
          },
          "evaluation_status": {
            "type": "string",
            "enum": ["passed", "failed", "pending"],
            "description": "Result of independent reference verification"
          },
          "evidence_tier": {
            "type": "string",
            "enum": ["meta_analysis", "rct", "cohort", "case_series", "case_report", "review", "opinion", "unclassified"],
            "description": "Highest evidence tier among this node's supporting references"
          },
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Display name of the entity"
                },
                "type": {
                  "type": "string",
                  "enum": ["gene", "variant", "phenotype", "drug", "pathway", "protein", "disease"],
                  "description": "Entity type"
                },
                "normalized_id": {
                  "type": "string",
                  "description": "Canonical identifier (HGNC symbol, HPO ID, OMIM ID, KEGG pathway, etc.)"
                }
              }
            },
            "description": "Normalized biomedical entities mentioned in this node"
          },
          "external_ids": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source", "id"],
              "properties": {
                "source": {
                  "type": "string",
                  "enum": ["clinicaltrials", "chembl"],
                  "description": "External data source"
                },
                "id": {
                  "type": "string",
                  "description": "Source-specific identifier (NCT ID, ChEMBL ID)"
                }
              }
            },
            "description": "Non-PubMed external reference identifiers"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "description": "Relationships between nodes",
      "items": {
        "type": "object",
        "required": ["source", "target", "relationship"],
        "properties": {
          "source": {
            "type": "string",
            "description": "Source node ID"
          },
          "target": {
            "type": "string",
            "description": "Target node ID"
          },
          "relationship": {
            "type": "string",
            "enum": ["is_part_of", "depends_on", "supports", "contradicts", "related_to", "derived_from", "mechanism_of"],
            "description": "Type of relationship"
          }
        }
      }
    },
    "cross_kg_edges": {
      "type": "array",
      "description": "Bidirectional links to nodes in other knowledge graphs",
      "items": {
        "type": "object",
        "required": ["local_node", "remote_kg", "remote_node", "relationship"],
        "properties": {
          "local_node": {
            "type": "string",
            "description": "Node ID in this KG"
          },
          "remote_kg": {
            "type": "string",
            "description": "Folder name of the remote KG"
          },
          "remote_node": {
            "type": "string",
            "description": "Node ID in the remote KG"
          },
          "relationship": {
            "type": "string",
            "enum": ["cross_kg_shared_evidence", "cross_kg_shared_entity", "cross_kg_related"],
            "description": "Type of cross-KG relationship"
          },
          "shared_refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Shared PMIDs, NCT IDs, or entity IDs that link these nodes"
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "required": ["total_nodes", "total_edges", "total_unique_pmids", "evaluation_passed", "evaluation_failed"],
      "properties": {
        "total_nodes": { "type": "integer", "minimum": 0 },
        "total_edges": { "type": "integer", "minimum": 0 },
        "total_unique_pmids": { "type": "integer", "minimum": 0 },
        "evaluation_passed": { "type": "integer", "minimum": 0 },
        "evaluation_failed": { "type": "integer", "minimum": 0 },
        "evidence_tier_distribution": {
          "type": "object",
          "description": "Count of nodes per evidence tier",
          "additionalProperties": { "type": "integer" }
        },
        "total_nct_ids": { "type": "integer", "minimum": 0 },
        "total_chembl_ids": { "type": "integer", "minimum": 0 },
        "ledger_total": { "type": "integer", "minimum": 0, "description": "Total PMIDs tracked in the PMID ledger" },
        "ledger_irrelevant": { "type": "integer", "minimum": 0, "description": "PMIDs in the ledger marked as irrelevant" }
      }
    }
  }
}
